useEffect(() => {
  const channel = supabase
    .channel("risk_scores")
    .on(
      "postgres_changes",
      { event: "INSERT", schema: "public", table: "risk_scores" },
      (payload) => {
        console.log("New row:", payload);
      }
    )
    .subscribe();

  return () => {
    supabase.removeChannel(channel);
  };
}, []);
